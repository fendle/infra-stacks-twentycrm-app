# =============================================================================
# Twenty CRM — non-secret application configuration
# =============================================================================
#
# Deployment target:
#
#   app-2
#   10.10.1.6
#
# Public URL:
#
#   https://crm.mynaghi.me
#
# Real secrets are stored in OpenBao.
#
# Application secret path:
#
#   secret/infra/twenty/app
#
# Database secret path:
#
#   secret/infra/twenty/db
#
# AppRole credentials on app-2:
#
#   /opt/secrets/twenty-app/openbao-approle.env
#
# Rendered runtime environment:
#
#   /opt/secrets/twenty-app/twenty.env
#
# Never add passwords, access keys, application secrets, SMTP credentials
# or database credentials to this file.
# =============================================================================


# =============================================================================
# Images
# =============================================================================

# Pin an exact Twenty version.
#
# Do not use "latest" in production.
#
# During the migration, use the same Twenty version as the old installation.
#
# Example:
# TAG=v2.19.0
TAG=

REDIS_TAG=7-alpine


# =============================================================================
# Public URL and private listener
# =============================================================================

SERVER_URL=https://crm.mynaghi.me

# Bind only to the Hetzner private IP of app-2.
APP_BIND_IP=10.10.1.6
APP_BIND_PORT=34000

# Twenty listens on this port inside the container.
NODE_PORT=3000

SERVER_KEEP_ALIVE_TIMEOUT_MS=65000

# Traefik on ingress-1 terminates HTTPS and forwards requests to app-2.
TRUST_PROXY=loopback,linklocal,uniquelocal


# =============================================================================
# PostgreSQL
# =============================================================================
#
# PostgreSQL credentials and connection values are read from:
#
#   secret/infra/twenty/db
#
# The render script builds PG_DATABASE_URL automatically.
#
# Expected database endpoint:
#
#   twenty-db.internal.mynaghi.me:5433
#
# Expected database:
#
#   default
#
# Expected application role:
#
#   twenty_rw
#
# PostgreSQL data on db-1:
#
#   /srv/postgresql/twenty/data
#
# This path is backed by the LUKS2-encrypted PostgreSQL volume.
# =============================================================================

PG_SSL_ALLOW_SELF_SIGNED=false

# High value for the first migration and upgrade.
# Review and reduce after the migration is stable.
PG_DATABASE_PRIMARY_TIMEOUT_MS=600000

PG_POOL_MAX_CONNECTIONS=10
PG_POOL_IDLE_TIMEOUT_MS=600000
PG_POOL_ALLOW_EXIT_ON_IDLE=true


# =============================================================================
# Hetzner Object Storage
# =============================================================================
#
# Access keys are read from:
#
#   secret/infra/twenty/app
#
# No local attachment storage is used.
# =============================================================================

# Use the actual bucket location.
#
# Examples:
#   nbg1
#   fsn1
STORAGE_S3_REGION=nbg1

STORAGE_S3_NAME=replace-with-twenty-bucket-name

STORAGE_S3_ENDPOINT=https://nbg1.your-objectstorage.com

# Keep disabled initially.
#
# Twenty will proxy uploads and downloads through the application server.
# This avoids browser-to-S3 CORS requirements during the initial migration.
STORAGE_S3_PRESIGNED_URL_ENABLED=false

STORAGE_S3_PRESIGNED_URL_EXPIRES_IN=900


# =============================================================================
# Logic Functions
# =============================================================================
#
# Required for Twenty Workflow Code nodes.
#
# LOCAL means the Logic Functions execute as child processes inside the
# Twenty runtime. This is not a hardened external sandbox.
# =============================================================================

LOGIC_FUNCTION_TYPE=LOCAL

# Separate feature from Workflow Code nodes.
CODE_INTERPRETER_TYPE=DISABLED


# =============================================================================
# Workspace model
# =============================================================================

IS_CONFIG_VARIABLES_IN_DB_ENABLED=false

IS_MULTIWORKSPACE_ENABLED=false

IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=true


# =============================================================================
# Authentication
# =============================================================================

AUTH_PASSWORD_ENABLED=true

SIGN_IN_PREFILLED=false

IS_EMAIL_VERIFICATION_REQUIRED=false


# =============================================================================
# Email
# =============================================================================
#
# EMAIL_SMTP_USER and EMAIL_SMTP_PASSWORD are read from:
#
#   secret/infra/twenty/app
# =============================================================================

EMAIL_DRIVER=smtp

EMAIL_FROM_ADDRESS=crm@mynaghi.me

EMAIL_FROM_NAME=Twenty CRM

EMAIL_SYSTEM_ADDRESS=system@mynaghi.me

EMAIL_SMTP_HOST=replace-with-smtp-host

EMAIL_SMTP_PORT=465

# false means TLS remains enabled.
EMAIL_SMTP_NO_TLS=false


# =============================================================================
# Security
# =============================================================================

# Restricts unsafe outbound requests where supported by Twenty.
OUTBOUND_HTTP_SAFE_MODE_ENABLED=true


# =============================================================================
# Telemetry, analytics and logging
# =============================================================================

TELEMETRY_ENABLED=false

ANALYTICS_ENABLED=false

LOG_LEVELS=log,error,warn,performance


# =============================================================================
# OpenTelemetry metrics
# =============================================================================
#
# Keep disabled until an OpenTelemetry Collector exists.
#
# Future example:
#
# METER_DRIVER=opentelemetry
# OTLP_COLLECTOR_METRICS_ENDPOINT_URL=http://otel-collector.internal.mynaghi.me:4318/v1/metrics
# =============================================================================

METER_DRIVER=

OTLP_COLLECTOR_METRICS_ENDPOINT_URL=


# =============================================================================
# Container resource limits
# =============================================================================

SERVER_MEMORY_LIMIT=4g
SERVER_CPU_LIMIT=2.0
SERVER_PIDS_LIMIT=512

WORKER_MEMORY_LIMIT=4g
WORKER_CPU_LIMIT=2.0
WORKER_PIDS_LIMIT=512

REDIS_MEMORY_LIMIT=1g
REDIS_CPU_LIMIT=1.0
REDIS_PIDS_LIMIT=128
